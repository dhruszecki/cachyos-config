# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
set $term foot
# Your preferred application launcher
set $menu fuzzel
# Socket FIFO para wob (barra visual de volumen/brillo)
set $WOBSOCK $XDG_RUNTIME_DIR/wob.sock
# Navegador (cambialo aca si queres usar otro: firefox / chromium / google-chrome-stable)
set $browser brave

input type:keyboard {
    # Dos layouts: us international (dead keys para acentos/ñ) y latam.
    xkb_layout us,latam
    # intl = dead keys en us: ' + a = á, ~ + n = ñ, etc. Sin variante en latam.
    xkb_variant intl,
    # Alterna entre layouts con Alt+Shift.
    xkb_options grp:alt_shift_toggle
}

# Tambien se puede alternar el layout con $mod+i
# kb: Cambiar layout de teclado
bindsym $mod+i input type:keyboard xkb_switch_layout next

### Output configuration
#
# Default wallpaper (more resolutions are available in /usr/share/backgrounds/sway/)
output * bg /usr/share/wallpapers/cachyos-wallpapers/Cachy_Topography.jpg fill
#
# Example configuration:
#
#   output HDMI-A-1 resolution 1920x1080 position 1920,0
#
# You can get the names of your outputs by running: swaymsg -t get_outputs

### Idle configuration
#
# Bloquea la pantalla a los 5 min, apaga las salidas a los 10 min, y bloquea
# antes de suspender. Las salidas se reactivan al volver de la inactividad.
exec swayidle -w \
         timeout 300 'swaylock -f -c 000000' \
         timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
         before-sleep 'swaylock -f -c 000000'

### Input configuration
#
# Example configuration:
#
#   input type:touchpad {
#       dwt enabled
#       tap enabled
#       natural_scroll enabled
#       middle_emulation enabled
#   }
#
#   input type:keyboard {
#       xkb_layout "eu"
#   }
#
# You can also configure each device individually.
# Read `man 5 sway-input` for more information about this section.

### Appearance (gaps & borders)
#
gaps inner 8
gaps outer 4
smart_gaps on
smart_borders on
default_border pixel 2
default_floating_border pixel 2

### Autostart
#
# Servicio de secretos (Secret Service). Necesario para GNOME Online Accounts
# (guardar el token de Google que usa GNOME Calendar). En Sway no hay sesion
# GNOME que lo arranque, asi que lo lanzamos aca.
exec /usr/bin/gnome-keyring-daemon --start --components=secrets
# Daemon de notificaciones
exec mako
# Layout automatico: alterna split horizontal/vertical segun la proporcion
exec autotiling
# Historial de portapapeles (guarda lo que se copia)
exec wl-paste --watch cliphist store
# Perfiles de monitor automaticos
exec kanshi
# Applet de Bluetooth en el tray
exec blueman-applet
# Barra principal
exec_always --no-startup-id 'pkill waybar; waybar'
# wob: crea el FIFO y lo lee para mostrar la barra visual
exec rm -f $WOBSOCK && mkfifo $WOBSOCK && tail -f $WOBSOCK | wob

### Window rules
#
for_window [app_id="pavucontrol"] floating enable
for_window [app_id="firefox" title="^Picture-in-Picture$"] floating enable, sticky enable
for_window [window_role="pop-up"] floating enable
for_window [window_role="dialog"] floating enable
# Reglas/keybindings específicos de cada usuario (ej. PWAs de trabajo) viven en
# ~/.config/sway/config.d/*.conf (ver include al final). NO globales.

### Key bindings
#
# Basics:
#
    # Start a terminal
    # kb: Terminal
    bindsym $mod+Return exec $term

    # Kill focused window
    # kb: Cerrar ventana
    bindsym $mod+Shift+q kill

    # Start your launcher
    # kb: Lanzador de apps
    bindsym $mod+d exec $menu

    # Historial de portapapeles (cliphist + fuzzel)
    # kb: Portapapeles (historial)
    bindsym $mod+Shift+v exec cliphist list | fuzzel --dmenu | cliphist decode | wl-copy

    # Ayuda: muestra todos los keybindings (incluye los custom) en fuzzel
    # kb: Ver atajos de teclado
    bindsym $mod+Shift+slash exec ~/.config/sway/show-keybindings.sh

    # Abrir el navegador
    # kb: Navegador
    bindsym $mod+Shift+b exec $browser

    # NOTA: los binds de apps de trabajo ($mod+Shift+m/w/g → Slack/WhatsApp/Meet)
    # se definen por-usuario en ~/.config/sway/config.d/*.conf (ver include final).

    # Drag floating windows by holding down $mod and left mouse button.
    # Resize them with right mouse button + $mod.
    # Despite the name, also works for non-floating windows.
    # Change normal to inverse to use left mouse button for resizing and right
    # mouse button for dragging.
    floating_modifier $mod normal

    # Reload the configuration file
    bindsym $mod+Shift+c reload

    # Exit sway (logs you out of your Wayland session)
    # kb: Salir de Sway
    bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'
#
# Moving around:
#
    # Move your focus around
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right
    # Or use $mod+[up|down|left|right]
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    # Move the focused window with the same, but add Shift
    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    bindsym $mod+Shift+$right move right
    # Ditto, with arrow keys
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right
#
# Workspaces:
#
    # Switch to workspace
    # OJO: $mod+6..0 NO se definen acá a propósito. Se definen por-contexto en config.d
    # para nombrar el workspace con su tag (6:Meet, 7:Drive, 8:Docs, ...) SIN disparar el
    # warning "overwriting binding Mod4+N" de sway (que aparecía al pisar estos binds):
    #   - 7..0  -> google-apps.conf (global, todos los usuarios)
    #   - 6     -> work-pwa.conf (daro-m, Meet) / personal.conf (daro, workspace 6 normal)
    bindsym $mod+1 workspace number 1
    bindsym $mod+2 workspace number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4
    bindsym $mod+5 workspace number 5
    # Move focused container to workspace
    bindsym $mod+Shift+1 move container to workspace number 1
    bindsym $mod+Shift+2 move container to workspace number 2
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace number 4
    bindsym $mod+Shift+5 move container to workspace number 5
    # Note: workspaces can have any name you want, not just numbers.
    # We just use 1-10 as the default.
#
# Layout stuff:
#
    # You can "split" the current object of your focus with
    # $mod+b or $mod+v, for horizontal and vertical splits
    # respectively.
    bindsym $mod+b splith
    bindsym $mod+v splitv

    # Switch the current container between different layout styles
    bindsym $mod+s layout stacking
    bindsym $mod+w layout tabbed
    bindsym $mod+e layout toggle split

    # Make the current focus fullscreen
    bindsym $mod+f fullscreen

    # Toggle the current focus between tiling and floating mode
    bindsym $mod+Shift+space floating toggle

    # Swap focus between the tiling area and the floating area
    bindsym $mod+space focus mode_toggle

    # Move focus to the parent container
    bindsym $mod+a focus parent
#
# Scratchpad:
#
    # Sway has a "scratchpad", which is a bag of holding for windows.
    # You can send windows there and get them back later.

    # Move the currently focused window to the scratchpad
    # --to-code: engancha a la tecla FISICA (keycode), no al keysym. Necesario
    # porque con doble layout (us,latam) Shift+minus emite 'underscore', no
    # 'minus', y sin --to-code el bind de esconder no dispararia nunca.
    bindsym --to-code $mod+Shift+minus move scratchpad

    # Show the next scratchpad window or hide the focused scratchpad window.
    # If there are multiple scratchpad windows, this command cycles through them.
    bindsym --to-code $mod+minus scratchpad show

# GNOME Calendar (global, todos los usuarios):
#   $mod+c muestra/oculta/lanza GNOME Calendar como ventana flotante en el
#   scratchpad (equivalente a "minimizar a la barra"). Cliente liviano para
#   Google Calendar vía GNOME Online Accounts.
    for_window [app_id="org.gnome.Calendar"] move scratchpad, scratchpad show, resize set 1000 720, move position center
    # kb: GNOME Calendar (personal)
    bindsym $mod+c exec /usr/local/bin/toggle-calendar
# Recordatorios de eventos -> popups de mako (el daemon no arranca solo en Sway).
exec /usr/lib/evolution-data-server/evolution-alarm-notify
#
# Resizing containers:
#
mode "resize" {
    # left will shrink the containers width
    # right will grow the containers width
    # up will shrink the containers height
    # down will grow the containers height
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    # Ditto, with arrow keys
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"
#
# Utilities:
#
    # Volumen via pamixer, con feedback visual en wob
    # kb: Subir volumen
    bindsym --locked XF86AudioRaiseVolume exec pamixer -ui 5 && pamixer --get-volume > $WOBSOCK
    # kb: Bajar volumen
    bindsym --locked XF86AudioLowerVolume exec pamixer -ud 5 && pamixer --get-volume > $WOBSOCK
    # kb: Silenciar audio
    bindsym --locked XF86AudioMute exec pamixer -t && ( pamixer --get-mute && echo 0 > $WOBSOCK || pamixer --get-volume > $WOBSOCK )
    # kb: Silenciar microfono
    bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle

    # Special keys to control media via playerctl
    # kb: Reproducir / Pausar
    bindsym --locked XF86AudioPlay exec playerctl play-pause
    # kb: Reproducir / Pausar
    bindsym --locked XF86AudioPause exec playerctl play-pause
    # kb: Pista anterior
    bindsym --locked XF86AudioPrev exec playerctl previous
    # kb: Pista siguiente
    bindsym --locked XF86AudioNext exec playerctl next
    # kb: Detener reproduccion
    bindsym --locked XF86AudioStop exec playerctl stop

    # Brillo via brightnessctl, con feedback visual en wob
    # kb: Bajar brillo
    bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%- && brightnessctl -m | cut -d, -f4 | tr -d '%' > $WOBSOCK
    # kb: Subir brillo
    bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+ && brightnessctl -m | cut -d, -f4 | tr -d '%' > $WOBSOCK

    # Screenshots con grim + slurp
    # Print: seleccionar region y copiar al portapapeles
    # kb: Captura de region (al portapapeles)
    bindsym Print exec grim -g "$(slurp)" - | wl-copy
    # Shift+Print: pantalla completa a archivo
    # kb: Captura de pantalla completa (a archivo)
    bindsym Shift+Print exec grim ~/Pictures/$(date +'%Y%m%d_%H%M%S').png

    # Bloquear la sesion con swaylock. Tipear contrasena para volver.
    # kb: Bloquear pantalla
    bindsym $mod+Shift+s exec swaylock -f -c 000000

    # Cerrar una sesion activa (incluye las de otros usuarios/VTs).
    # Muestra todas las sesiones en fuzzel, elegis cual terminar.
    # kb: Cerrar una sesion (loginctl)
    bindsym $mod+Ctrl+Shift+e exec loginctl list-sessions --no-legend | fuzzel --dmenu --prompt="Cerrar sesion> " | awk '{print $1}' | xargs -r loginctl terminate-session

    # Cambiar de sesion: muestra sesiones activas en fuzzel y salta directo.
    # Si no hay otra sesion abierta, ofrece abrir el greeter.
    # La sesion actual queda bloqueada con swaylock (una sola contrasena al volver).
    # kb: Cambiar de sesion
    bindsym $mod+Ctrl+Shift+s exec sway-session-switch

#
# Status Bar:
#
# Usamos waybar (ver ### Autostart). La barra default de swaybar quedo
# desactivada. Si alguna vez queres volver a ella, descomenta este bloque
# y quita 'exec waybar' del autostart.
# bar {
#     position top
#     status_command while date +'%Y-%m-%d %X'; do sleep 1; done
#     colors {
#         statusline #ffffff
#         background #323232
#         inactive_workspace #32323200 #32323200 #5c5c5c
#     }
# }

include /etc/sway/config.d/*

# Overrides/reglas por-usuario (ej. PWAs de trabajo solo para daro-m).
# Cada usuario pone sus .conf acá; si no existe el dir, el glob no falla.
include ~/.config/sway/config.d/*.conf
