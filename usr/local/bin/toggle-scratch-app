#!/bin/sh
# Toggle de una app en el scratchpad de Sway, identificada por una REGEX de app_id.
#   - si hay una ventana visible (en un workspace) -> la manda al scratchpad (oculta)
#   - si hay una ventana oculta (en el scratchpad)  -> la muestra
#   - si no existe ninguna                          -> la lanza (resto de args)
#
# Uso: toggle-scratch-app <regex_app_id> <comando para lanzarla...>
#
# Pensado para PWAs de Brave/Chromium: bajo Wayland IGNORAN --class y reciben un app_id
# autogenerado de la URL del --app (tipo "brave-<host>...-Default"). Por eso se matchea
# por regex del host (ej. '^brave-app\.slack\.com'). Funciona aunque la ventana ya
# estuviera abierta de antes (no necesita la regla for_window para ocultar).
pattern="$1"
shift

tree=$(swaymsg -t get_tree)

exists=$(printf '%s' "$tree" | jq --arg re "$pattern" \
    '[recurse(.nodes[]?, .floating_nodes[]?) | select(.app_id != null and (.app_id | test($re)))] | length')

if [ "${exists:-0}" -gt 0 ]; then
    # ¿Está dentro del scratchpad (oculta)?
    inscratch=$(printf '%s' "$tree" | jq --arg re "$pattern" \
        '[.. | objects | select(.name=="__i3_scratch") | recurse(.nodes[]?, .floating_nodes[]?) | select(.app_id != null and (.app_id | test($re)))] | length')
    if [ "${inscratch:-0}" -gt 0 ]; then
        swaymsg "[app_id=\"$pattern\"] scratchpad show" >/dev/null
    else
        swaymsg "[app_id=\"$pattern\"] move scratchpad" >/dev/null
    fi
else
    exec "$@"
fi
