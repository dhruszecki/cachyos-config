[Desktop Entry]
Version=1.0
Type=Application
Name=Google Sheets (PWA)
GenericName=Spreadsheet
Comment=Google Sheets en Brave, modo app, Wayland nativo
Exec=/usr/bin/brave --app=https://docs.google.com/spreadsheets/u/0/
Icon=x-office-spreadsheet
Terminal=false
Categories=Office;Spreadsheet;
StartupNotify=true
